FROM --platform=$BUILDPLATFORM node:18 AS base

# Install basic tools and build essentials
RUN apt-get update && apt-get install -y \
    git \
    screen \
    wget \
    gcc \
    g++ \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Detect architecture and install appropriate Go version
RUN arch=$(uname -m); \
    case "$arch" in \
        'x86_64') \
            GOARCH='amd64' \
            ;; \
        'aarch64') \
            GOARCH='arm64' \
            ;; \
        *) \
            echo "Unsupported architecture: $arch" \
            exit 1 \
            ;; \
    esac; \
    wget https://go.dev/dl/go1.22.0.linux-${GOARCH}.tar.gz && \
    tar -C /usr/local -xzf go1.22.0.linux-${GOARCH}.tar.gz && \
    rm go1.22.0.linux-${GOARCH}.tar.gz

ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOPATH="/root/go"
ENV PATH="${GOPATH}/bin:${PATH}"

# Set up work directory
WORKDIR /app

RUN git clone https://github.com/lonelycode/langchaingo.git /langchaingo

# Install Air for Go hot reloading
RUN go install github.com/air-verse/air@latest

# Copy package files first to leverage Docker cache
COPY ui/admin-frontend/package*.json ./ui/admin-frontend/

# Install frontend dependencies
RUN cd ui/admin-frontend && npm install

# Copy the rest of the application
COPY . .

# Create empty build directory for Go static build
RUN mkdir -p ui/admin-frontend/build && \
    touch ui/admin-frontend/build/empty

RUN touch /app/midsommar.db && \
    chmod 666 /app/midsommar.db

# Expose ports for frontend and backend
EXPOSE 3000 8080

# Use a shell script to run both services
COPY docker-entrypoint-dev.sh /
RUN chmod +x /docker-entrypoint-dev.sh

ENTRYPOINT ["/docker-entrypoint-dev.sh"]
