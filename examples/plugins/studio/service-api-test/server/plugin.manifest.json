{
  "id": "com.tyk.service-api-test",
  "version": "1.0.0",
  "name": "Service API E2E Test",
  "description": "Comprehensive end-to-end testing of all AI Studio service APIs with visual results",
  "capabilities": {
    "hooks": ["studio_ui"],
    "primary_hook": "studio_ui"
  },
  "permissions": {
    "rpc": ["call"],
    "routes": ["GET:/plugin/com.tyk.service-api-test/rpc/*"],
    "ui": ["sidebar.register", "route.register"],
    "services": [
      "llms.read",
      "llms.write",
      "apps.read",
      "apps.write",
      "tools.read",
      "tools.write",
      "datasources.read",
      "datasources.write",
      "tags.read",
      "tags.write",
      "filters.read",
      "filters.write",
      "pricing.read",
      "pricing.write",
      "data-catalogues.read",
      "data-catalogues.write",
      "kv.readwrite"
    ]
  },
  "ui": {
    "slots": [
      {
        "slot": "sidebar.section",
        "label": "API Tests",
        "icon": "/assets/test-icon.svg",
        "items": [
          {
            "type": "route",
            "path": "/admin/service-api-test",
            "title": "E2E Test Runner",
            "mount": {
              "kind": "webc",
              "tag": "service-api-test-dashboard",
              "entry": "/ui/webc/test-dashboard.js",
              "props": {
                "rpcBase": "/plugin/com.tyk.service-api-test/rpc"
              }
            }
          }
        ]
      }
    ]
  },
  "compat": {
    "app": ">=2.6 <3.0",
    "api": ["ui-v1", "rpc-v1"]
  },
  "security": {
    "csp": "script-src 'self'; object-src 'none'; frame-ancestors 'none'"
  },
  "assets": ["/assets/test-icon.svg", "/ui/webc/test-dashboard.js"]
}
