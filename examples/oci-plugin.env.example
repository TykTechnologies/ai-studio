# File-based keys (for non-containerized deployments)
# OCI_PLUGINS_PUBKEY_FILE_CI=/etc/microgateway/keys/ci.pub
# OCI_PLUGINS_PUBKEY_FILE_PROD=/etc/microgateway/keys/prod.pub

# =============================================================================
# Registry Authentication Configuration
# =============================================================================

# Nexus Registry Authentication
OCI_PLUGINS_REGISTRY_NEXUS_USERNAME=plugin-reader
OCI_PLUGINS_REGISTRY_NEXUS_PASSWORDENV=NEXUS_PASSWORD

# Harbor Registry Authentication
OCI_PLUGINS_REGISTRY_HARBOR_TOKENENV=HARBOR_TOKEN

# Docker Hub Authentication (if needed)
# OCI_PLUGINS_REGISTRY_DOCKER_IO_USERNAME=your-username
# OCI_PLUGINS_REGISTRY_DOCKER_IO_TOKENENV=DOCKER_HUB_TOKEN

# =============================================================================
# Registry Authentication Credentials
# =============================================================================

# Store actual credentials separately for security
NEXUS_PASSWORD=your-nexus-password-here
HARBOR_TOKEN=your-harbor-token-here
# DOCKER_HUB_TOKEN=your-docker-hub-token-here

# =============================================================================
# Standard Microgateway Configuration
# =============================================================================

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_DSN=file:./data/microgateway.db?cache=shared&mode=rwc

# Server Configuration
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Security Configuration (required)
JWT_SECRET=change-me-in-production-to-something-secure
ENCRYPTION_KEY=change-me-32-character-secret!!
MICROGATEWAY_ENCRYPTION_KEY=change-this-32char-key-for-prod!

# =============================================================================
# Example Plugin Configurations in Database
# =============================================================================

# After setting up environment, you can create plugins with these commands:
#
# oci://nexus.company.com/plugins/auth@sha256:abc123?pubkey=CI
# oci://harbor.company.com/plugins/rate-limiter@sha256:def456?pubkey=PROD&arch=linux/amd64
# oci://registry.company.com/plugins/analytics@sha256:ghi789?pubkey=1
# oci://localhost:5000/plugins/dev-test:latest?pubkey=DEV

# =============================================================================
# Development vs Production Settings
# =============================================================================

# For Development (disable signature verification)
# OCI_PLUGINS_REQUIRE_SIGNATURE=false
# OCI_PLUGINS_ALLOWED_REGISTRIES=localhost:5000,registry-1.docker.io

# For Production (strict security)
# OCI_PLUGINS_REQUIRE_SIGNATURE=true
# OCI_PLUGINS_ALLOWED_REGISTRIES=nexus.company.com,harbor.company.com