-----END PUBLIC KEY-----"

OCI_PLUGINS_PUBKEY_PROD="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA8yF3K4N8L2R7W6E1P5C9
A3Y2V7Q4T8G1B5D9E2S6F0H4L7P3V1C8N5A2Y6W9Q7R4T1G3B8D2E5S9F6H0L4P7
