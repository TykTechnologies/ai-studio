# Generated by: gromit policy

FROM debian:bookworm-slim as DEB
ARG TARGETARCH

ENV DEBIAN_FRONTEND=noninteractive

COPY *${TARGETARCH}.deb /
RUN rm -f /*fips*.deb && dpkg -i /tyk-ai-studio*${TARGETARCH}.deb && rm /*.deb

FROM gcr.io/distroless/base-debian12:nonroot

COPY --from=DEB /opt/tyk-ai-studio /opt/tyk-ai-studio

ARG PORTS
EXPOSE $PORTS

WORKDIR /opt/tyk-ai-studio/

ENTRYPOINT ["/opt/tyk-ai-studio/tyk-ai-studio" ]
CMD [ "-env=/opt/tyk-ai-studio/.env" ]
