# Generated by: gromit policy

FROM debian:bookworm-slim as DEB
ARG TARGETARCH

ENV DEBIAN_FRONTEND=noninteractive

COPY *${TARGETARCH}.deb /
RUN rm -f /*fips*.deb && dpkg -i /midsommar*${TARGETARCH}.deb && rm /*.deb

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=DEB /opt/midsommar /opt/midsommar

ARG PORTS
EXPOSE $PORTS

WORKDIR /opt/midsommar/

ENTRYPOINT ["/opt/midsommar/midsommar" ]
CMD [ "--conf=/opt/midsommar/midsommar.conf" ]
