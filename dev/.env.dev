# =============================================================================
# Tyk AI Studio - Development Environment Configuration
# =============================================================================
#
# Copy this file to .env in the dev/ directory:
#   cp .env.dev .env
#
# Then edit .env with your configuration.
# DO NOT commit .env files with real credentials!
#
# =============================================================================

# -----------------------------------------------------------------------------
# Edition Configuration
# -----------------------------------------------------------------------------
# ce = Community Edition (default)
# ent = Enterprise Edition (requires enterprise submodule and license)
EDITION=ce

# -----------------------------------------------------------------------------
# Core Application Settings
# -----------------------------------------------------------------------------
DEVMODE=true
DEBUG_HTTP=false
DEBUG_HTTP_PROXY=false
ECHO_CONVERSATION=true
ALLOW_REGISTRATIONS=true

# URLs - these are set for Docker Compose networking
# Frontend served from port 3000, backend API from 8080
SITE_URL=http://localhost:3000
DOCS_URL=http://localhost:8989
PROXY_URL=http://localhost:8080
TOOL_DISPLAY_URL=http://localhost:9090
DATASOURCE_DISPLAY_URL=http://localhost:9090

# Documentation server
DOCS_PORT=9898
DOCS_DISABLED=false

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL for dev - matches production)
# -----------------------------------------------------------------------------
# Note: In Docker Compose, the hostname is 'postgres' (service name)
DATABASE_TYPE=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/midsommar?sslmode=disable

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Secret key for encryption (change in production!)
# Used for encrypting secrets and SSO (if Enterprise Edition)
TYK_AI_SECRET_KEY=822d3d1e0e2d849263e45fc7bb842364

# Encryption key for microgateway communication
MICROGATEWAY_ENCRYPTION_KEY=822d3d1e0e2d849263e45fc7bb842364

# -----------------------------------------------------------------------------
# User Registration
# -----------------------------------------------------------------------------
# Filter allowed signup domains (comma-separated, empty = allow all)
# FILTER_SIGNUP_DOMAINS=tyk.io,example.com
FILTER_SIGNUP_DOMAINS=

# Signup mode: "both", "email", "sso"
DEFAULT_SIGNUP_MODE=both

# Default budget for new apps
DEFAULT_APP_BUDGET=100.00

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Options: trace, debug, info, warn, error
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# SMTP Configuration (Optional - for email notifications)
# -----------------------------------------------------------------------------
# SMTP_SERVER=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# FROM_EMAIL=noreply@localhost

# -----------------------------------------------------------------------------
# LLM Provider API Keys (Optional - add your keys to test LLM features)
# -----------------------------------------------------------------------------
# OpenAI (GPT-4, GPT-3.5, etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_AI_KEY=

# Google AI (Gemini)
GOOGLE_AI_KEY=

# Cohere
COHERE_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# AWS Bedrock
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# =============================================================================
# Hub-and-Spoke gRPC Control Server Configuration
# =============================================================================
# Gateway mode: "standalone" (default) or "control" (hub that manages edge gateways)
# Set to "control" to enable gRPC control server for managing edge microgateway instances
GATEWAY_MODE=control

# gRPC Control Server Configuration
GRPC_PORT=50051
GRPC_HOST=0.0.0.0

# gRPC TLS Configuration
# TLS is ENABLED by default for production security
# For local development, we disable TLS
GRPC_TLS_INSECURE=true
# GRPC_TLS_CERT_PATH=/path/to/server-cert.pem
# GRPC_TLS_KEY_PATH=/path/to/server-key.pem

# gRPC Authentication
# Required for authenticating edge microgateway instances connecting to control
GRPC_AUTH_TOKEN=822d3d1e0e2d849263e45fc7bb842364
# GRPC_AUTH_TOKEN_NEXT=  # Next token for zero-downtime rotation

# =============================================================================
# Enterprise Edition Only
# =============================================================================
# License key for Enterprise Edition features
# Required when EDITION=ent
# TYK_AI_LICENSE=your-license-key-here

# SSO Configuration (Enterprise Edition)
# TIB_ENABLED is deprecated - SSO availability is determined by edition
# TIB_ENABLED=true
# Configure SSO profiles via the Admin UI at /admin/sso-profiles

# Telemetry configuration (Enterprise Edition)
# LICENSE_TELEMETRY_URL=https://telemetry.tyk.technology/api/track
# LICENSE_TELEMETRY_PERIOD=1h
# LICENSE_VALIDITY_CHECK_PERIOD=24h
# LICENSE_DISABLE_TELEMETRY=false
# LICENSE_TELEMETRY_CONCURRENCY=20

# =============================================================================
# Plugin Configuration
# =============================================================================

# Plugin Security (Community Edition - Always Available)
# - Path whitelisting (filesystem security)
# - Checksum validation (integrity checking)

# Plugin Security (Enterprise Edition Only)
# - GRPC host whitelisting (blocks internal network access)
# - OCI signature verification (Cosign-based supply chain security)

# Allow plugins to access internal network addresses
# Default: false (blocks 10.x, 192.168.x, 127.x, ::1, etc.)
# Set to true ONLY in development environments
ALLOW_INTERNAL_NETWORK_ACCESS=true

# =============================================================================
# OCI Plugin Configuration (Optional)
# =============================================================================
# To enable OCI plugin support, set AI_STUDIO_OCI_CACHE_DIR
# If not set, AI Studio will only support local plugin binaries

# Enable OCI plugin support by setting cache directory
AI_STUDIO_OCI_CACHE_DIR=/app/data/cache/plugins

# Cache configuration
# AI_STUDIO_OCI_MAX_CACHE_SIZE=1073741824  # 1GB default

# Security settings
AI_STUDIO_OCI_REQUIRE_SIGNATURE=true    # Default false for AI Studio (more permissive) - Enterprise Edition only
AI_STUDIO_OCI_ALLOWED_REGISTRIES=localhost:5100,docker.tyk.io
OCI_PLUGINS_PUBKEY_FILE_LIVE=./keys/plugins/plugin-live.pub

# Network settings
AI_STUDIO_OCI_TIMEOUT=30s
AI_STUDIO_OCI_RETRY_ATTEMPTS=3

# Garbage collection
AI_STUDIO_OCI_GC_INTERVAL=24h
AI_STUDIO_OCI_KEEP_VERSIONS=3

# Advanced settings
AI_STUDIO_OCI_INSECURE_REGISTRIES=localhost:5100

# =============================================================================
# OCI Registry Authentication
# =============================================================================
# Authentication for private registries
# Replace MYREGISTRY_COM with your registry domain (dots become underscores)

# Basic authentication
# OCI_PLUGINS_REGISTRY_MYREGISTRY_COM_USERNAME=myuser
# OCI_PLUGINS_REGISTRY_MYREGISTRY_COM_TOKEN_ENV=MY_REGISTRY_TOKEN

# =============================================================================
# OCI Public Keys for Signature Verification (Enterprise Edition Only)
# =============================================================================
# Numbered keys (content directly in environment variable)
# OCI_PLUGINS_PUBKEY_1="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# File-based keys (path to public key file)
# OCI_PLUGINS_PUBKEY_FILE_COSIGN=/etc/ai-studio/cosign.pub
