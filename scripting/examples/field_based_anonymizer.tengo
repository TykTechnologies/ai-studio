// Configuration
fields_to_anonymize := ["emailAddress", "displayName", "email", "mail", "name"]
fields_to_analyse := ["summary"]
llmID := 9
confID := 9

json := import("json")
tyk := import("tyk")

prompt := `You are an AI Assistant. Your job is to REPLACE Personally identifiable information (PII) with asterisks (***********) to protect the information of users. PII is defined as:
- Full Name
- Home address
- Zip Code
- Post code
- Email address
- Phone numbers
- Date of birth
- Birthday
- Social Security Number (SSN) or national ID numbers
- Passport, or driver's license numbers
- Racial or ethnic origin
- Political opinions
- Religious or philosophical beliefs
- Trade union membership
- Sexual orientation or sex life
- Bank account numbers
- Credit or debit card information
- Tax information
- Job titles
- Employment history

Respond only with your modified, safe text.
ONLY RESPOND WITH THE REDACTED COPY OF THE TEXT.
REPLACE ALL occurrences of Personally Identifiable Information in the content with asterisks (***********).

Anonymize the following data and ONLY RESPOND WITH THE ANONYMIZED DATA:

START DATA:
`

search_llm := func(p) {
    toSend := prompt + p
	response := tyk.llm(llmID, confID, toSend)
	return response
}

search_and_null := func(obj) {
    // Handle different types
    if is_map(obj) {
        // For maps/objects, check each key
        for k, v in obj {
            // Check if key is in our list of fields to anonymize
            for field in fields_to_anonymize {
                if obj[k] != "" {
                    if k == field {
                        obj[k] = "**********"
                        break
                    }
                }
            }

            // check if it's in keys to process
            for field in fields_to_analyse {
                if k == field {
                    if obj[k] != "" {
                        obj[k] = search_llm(obj[k])
                        break
                    }
                }
            }

            if is_map(v) || is_array(v) {
                // Recursively process nested objects/arrays
                search_and_null(v)
            }
        }
    } else if is_array(obj) {
        // For arrays, process each element
        for i := 0; i < len(obj); i++ {
            if is_map(obj[i]) || is_array(obj[i]) {
                search_and_null(obj[i])
            }
        }
    }
    return obj
}

filter := func(input) {
    json_data := json.decode(input)
    if !is_error(json_data) {
        clean := search_and_null(json_data)
        asStr := json.encode(clean)

        return string(asStr)
    } else {
        // Handle JSON decode error
        return "Failed to decode JSON"
    }

    return "something went wrong..."
}

result := filter(payload)
